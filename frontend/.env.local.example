# Groq — skill extraction after screen recording
GROQ_API_KEY=

# Sui network (mainnet | testnet | devnet) — must match the network in Phantom
NEXT_PUBLIC_SUI_NETWORK=testnet

# Tatum Sui JSON-RPC (https://dashboard.tatum.io)
NEXT_PUBLIC_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
# Used by /api/sui/rpc proxy and server scripts (do not rely on browser → Tatum direct; CORS blocks it)
TATUM_API_KEY=
# Min ms between each Sui RPC call during publish + pauses between publish steps (default 5000)
# NEXT_PUBLIC_PUBLISH_RPC_GAP_MS=5000

# Deployed openclu_skill package v1 (Seal requires first package version — run: node scripts/deploy-testnet.mjs)
NEXT_PUBLIC_OPENCLU_SKILL_PACKAGE_ID=

# Seal threshold (number of key servers required to decrypt)
NEXT_PUBLIC_SEAL_THRESHOLD=2

# Supabase — metadata catalog only (no skill content). Run supabase/skill_catalog.sql first.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never expose as NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Optional: cache dir for @xenova/transformers (embeddings). Defaults to ./.cache/transformers
# TRANSFORMERS_CACHE=./.cache/transformers
